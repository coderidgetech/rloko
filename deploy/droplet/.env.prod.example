# Production — copy to .env.prod  (gitignored, never commit real secrets)
# cp .env.prod.example .env.prod
# Then: make deploy-prod   or   ./deploy.sh ghcr --env prod

# ─── Domain ───────────────────────────────────────────────────────────────────
PUBLIC_DOMAIN=rloko.com
APP_BASE_URL=https://rloko.com
CORS_ALLOWED_ORIGINS=https://rloko.com,https://www.rloko.com

# ─── Docker images (from GHCR) ────────────────────────────────────────────────
API_IMAGE=ghcr.io/yourgithubuser/rloco-api:latest
WEB_IMAGE=ghcr.io/yourgithubuser/rloco-web:prod

# ─── Frontend VITE_* (baked at image build time) ─────────────────────────────
VITE_API_URL=https://rloko.com/api
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
VITE_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
VITE_GOOGLE_MAPS_API_KEY=AIza...
VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123
VITE_FIREBASE_VAPID_KEY=BExxx...

# ─── Backend ─────────────────────────────────────────────────────────────────
ENV=production
PORT=8080

MONGO_INITDB_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=change_this_VERY_strong_password
MONGODB_URI=mongodb://root:change_this_VERY_strong_password@mongo:27017/rloco?authSource=admin

JWT_SECRET=generate_with_openssl_rand_hex_64
JWT_EXPIRY=24h

# ─── Twilio (OTP phone registration) ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_PHONE_NUMBER=

# ─── Firebase (Push Notifications) — paste service account JSON on one line ──
FCM_SERVICE_ACCOUNT_JSON=

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_sendgrid_api_key
SMTP_FROM=noreply@rloko.com
SMTP_FROM_NAME=Rloko

# ─── Storage (S3 / Cloudflare R2) ────────────────────────────────────────────
STORAGE_TYPE=s3
STORAGE_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=
STORAGE_PUBLIC_URL=https://pub-xxxx.r2.dev

# ─── Google (Maps / OAuth) ────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_MAPS_BROWSER_KEY=AIza...

# ─── Shippo (shipping rates) ─────────────────────────────────────────────────
SHIPPO_API_KEY=
SHIPPO_FROM_NAME=Rloko Warehouse
SHIPPO_FROM_EMAIL=shipping@example.com
SHIPPO_FROM_PHONE=+1 555 123 4567
SHIPPO_FROM_STREET1=123 Fashion Avenue
SHIPPO_FROM_CITY=New York
SHIPPO_FROM_STATE=NY
SHIPPO_FROM_ZIP=10001
SHIPPO_FROM_COUNTRY=US
SHIPPO_PARCEL_LENGTH=10
SHIPPO_PARCEL_WIDTH=8
SHIPPO_PARCEL_HEIGHT=4
SHIPPO_PARCEL_WEIGHT=0.5
SHIPPO_DISTANCE_UNIT=in
SHIPPO_MASS_UNIT=lb

# ─── GHCR auth ───────────────────────────────────────────────────────────────
GHCR_USER=yourgithubuser
GHCR_PAT=ghp_...
