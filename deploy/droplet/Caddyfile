# Domain is set via PUBLIC_DOMAIN in .env.dev / .env.prod (passed to caddy container).
# Let’s Encrypt: DNS must resolve to this server’s IP; ports 80 and 443 must be open.
# Local testing without DNS: set PUBLIC_DOMAIN=:80 in your .env file.

{$PUBLIC_DOMAIN:dev.rloko.com} {
	@backend path /api* /health /ready
	handle @backend {
		reverse_proxy http://api:8080
	}
	handle {
		reverse_proxy http://web:80
	}
}
