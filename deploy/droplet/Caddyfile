# Staging: dev.rloko.com. For local testing without DNS, temporarily use: :80 { ... }
# Let’s Encrypt: name must resolve (GoDaddy: A record host "dev" -> Droplet IP), ports 80/443 open.

dev.rloko.com {
	@backend path /api* /health /ready
	handle @backend {
		reverse_proxy http://api:8080
	}
	handle {
		reverse_proxy http://web:80
	}
}
