# Copy: cp .env.example .env   (never commit .env)

# API mode: use staging on dev until Twilio/keys are complete (avoids process exit; OTP disabled).
# ENV=staging
# or production (requires TWILIO_* and strong JWT; see backend main.go)
# ENV=production

# Public site URL (CORS, links) — currently staging: dev subdomain
APP_BASE_URL=https://dev.rloko.com
CORS_ALLOWED_ORIGINS=https://dev.rloko.com

# Frontend build: must match the public API URL (same host + /api). CI uses the same; change both when moving to prod.
VITE_API_URL=https://dev.rloko.com/api

# Mongo (in-cluster compose): match MONGO_INITDB_ROOT_* and database name
MONGO_INITDB_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=change_this_strong_password
# Use root user for a single-node dev droplet; tighten for production.
MONGODB_URI=mongodb://root:change_this_strong_password@mongo:27017/rloco?authSource=admin

# Same value as a long random string (or remove Dockerfile ENV by using a secret-only flow later)
JWT_SECRET=generate_with_openssl_rand_hex_64

# Twilio (required at backend startup)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# If using Managed MongoDB instead, delete the mongo service in docker-compose.yml, remove
# api -> mongo depends_on, and set MONGODB_URI=your Atlas or DO connection string.

# Pre-built images (fast Droplet deploy — use docker-compose.ghcr.yml, see deploy/droplet/README.md)
# API_IMAGE=ghcr.io/yourgithubuser/rloco-api:latest
# WEB_IMAGE=ghcr.io/yourgithubuser/rloco-web:latest
