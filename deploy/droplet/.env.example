# Copy: cp .env.example .env   (never commit .env)

# ENV: default in compose is production (omit this line or set below).
# — dev.rloko.com with the SAME Twilio / Mongo / JWT as production: use ENV=production and only
#   change APP_BASE_URL, CORS_ALLOWED_ORIGINS, VITE_API_URL to dev (Twilio and DB match prod).
# — optional ENV=staging: server can start without Twilio (OTP off); with Twilio set, behavior is
#   the same as production for auth/OTP; rate limits and stricter error responses stay looser.
ENV=production

# Public site URL (CORS, links) — dev host
APP_BASE_URL=https://dev.rloko.com
CORS_ALLOWED_ORIGINS=https://dev.rloko.com

# Optional: global API requests per IP per minute (default 500 if unset in production).
# API_RATE_LIMIT_RPM=800

# Frontend build: must match the public API URL (same host + /api). CI uses the same; change both when moving to prod.
VITE_API_URL=https://dev.rloko.com/api

# Google Maps (Vite: baked at image build). Same key as backend GOOGLE_MAPS_API_KEY if API serves Places.
# VITE_GOOGLE_MAPS_API_KEY=

# Google Sign-In (Vite: baked at *image build* time, not at container runtime)
# — GHCR images: add secret VITE_GOOGLE_CLIENT_ID in the repo, then re-run "Publish Droplet images (GHCR)".
# — Build on the Droplet (./deploy.sh build): set here and in frontend/.env if you build from compose.
# VITE_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

# Mongo (in-cluster compose): match MONGO_INITDB_ROOT_* and database name
MONGO_INITDB_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=change_this_strong_password
# Use root user for a single-node dev droplet; tighten for production.
MONGODB_URI=mongodb://root:change_this_strong_password@mongo:27017/rloco?authSource=admin

# Same value as a long random string (or remove Dockerfile ENV by using a secret-only flow later)
JWT_SECRET=generate_with_openssl_rand_hex_64

# Twilio (optional for boot; add when you need phone registration OTP — same as prod is fine on dev)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Shippo (optional) — live carrier rates on POST /api/shipping/calculate. Same names as backend/.env.
# Leave SHIPPO_API_KEY empty to skip Shippo and use default/stored shipping methods.
# After editing: ./deploy.sh env   or   docker compose -f docker-compose.ghcr.yml up -d
SHIPPO_API_KEY=
# SHIPPO_BASE_URL=https://api.goshippo.com
SHIPPO_FROM_NAME=Rloco Warehouse
SHIPPO_FROM_EMAIL=shipping@example.com
SHIPPO_FROM_PHONE=+1 555 123 4567
SHIPPO_FROM_STREET1=123 Fashion Avenue
SHIPPO_FROM_STREET2=
SHIPPO_FROM_CITY=New York
SHIPPO_FROM_STATE=NY
SHIPPO_FROM_ZIP=10001
SHIPPO_FROM_COUNTRY=US
SHIPPO_PARCEL_LENGTH=10
SHIPPO_PARCEL_WIDTH=8
SHIPPO_PARCEL_HEIGHT=4
SHIPPO_PARCEL_WEIGHT=0.5
SHIPPO_DISTANCE_UNIT=in
SHIPPO_MASS_UNIT=lb

# If using Managed MongoDB instead, delete the mongo service in docker-compose.yml, remove
# api -> mongo depends_on, and set MONGODB_URI=your Atlas or DO connection string.

# Pre-built images (fast Droplet deploy — use docker-compose.ghcr.yml, see deploy/droplet/README.md)
# API_IMAGE=ghcr.io/yourgithubuser/rloco-api:latest
# WEB_IMAGE=ghcr.io/yourgithubuser/rloco-web:latest
