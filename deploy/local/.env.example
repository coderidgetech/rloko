# Local Docker stack — copy to .env (gitignored)
# cp .env.example .env   or   make setup

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=password
MONGODB_URI=mongodb://admin:password@mongo:27017/rloco?authSource=admin

# ─── MinIO (local object storage) ────────────────────────────────────────────
STORAGE_TYPE=s3
STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=rloco-uploads

# ─── Backend ─────────────────────────────────────────────────────────────────
JWT_SECRET=local-dev-secret-change-me
JWT_EXPIRY=24h
APP_BASE_URL=http://localhost:3000

# ─── Frontend VITE_* (baked into the web image at build time) ─────────────────
VITE_API_URL=http://localhost:8080/api
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
VITE_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
VITE_GOOGLE_MAPS_API_KEY=AIza...
VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123
VITE_FIREBASE_VAPID_KEY=BExxx...

# ─── Optional: Twilio, Stripe, SMTP (leave empty to disable) ─────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@localhost
SMTP_FROM_NAME=Rloko
FCM_SERVICE_ACCOUNT_JSON=
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_MAPS_BROWSER_KEY=AIza...
